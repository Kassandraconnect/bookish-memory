import os
import asyncio
from pydantic import BaseModel, Field
from langchain_core.tools import tool
from playwright.async_api import async_playwright
from huggingface_hub import HfApi

# --- SHELL & FILESYSTEM TOOLS ---

class ShellInput(BaseModel):
    command: str = Field(description=\"The shell command to execute (e.g., terraform apply -auto-approve, docker build)\")

@tool(\"execute_shell\", args_schema=ShellInput)
async def execute_shell(command: str) -> str:
    \"\"\"Executes a system shell command asynchronously in the workspace directory.\"\"\"
    cwd = os.path.abspath(\"./workspace\")
    os.makedirs(cwd, exist_ok=True)
    
    process = await asyncio.create_subprocess_shell(
        command,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.PIPE,
        cwd=cwd
    )
    stdout, stderr = await process.communicate()
    
    output = f\"EXIT CODE: {process.returncode}\
\"
    if stdout: output += f\"STDOUT:\
{stdout.decode()}\
\"
    if stderr: output += f\"STDERR:\
{stderr.decode()}\
\"
    return output

class WriteFileInput(BaseModel):
    filepath: str = Field(description=\"Relative path inside workspace (e.g., 'main.tf')\")
    content: str = Field(description=\"Content of the file\")

@tool(\"write_file\", args_schema=WriteFileInput)
async def write_file(filepath: str, content: str) -> str:
    \"\"\"Writes code or configuration to a file in the workspace.\"\"\"
    base_dir = os.path.abspath(\"./workspace\")
    full_path = os.path.abspath(os.path.join(base_dir, filepath))
    
    if not full_path.startswith(base_dir):
        return \"ERROR: Path traversal detected. Blocked.\"
        
    os.makedirs(os.path.dirname(full_path), exist_ok=True)
    with open(full_path, \"w\", encoding=\"utf-8\") as f:
        f.write(content)
    return f\"SUCCESS: File written to {filepath}\"

# --- BROWSER / PERSONAL ADMIN TOOLS ---

class BrowserInput(BaseModel):
    url: str = Field(description=\"The URL to navigate to\")
    action: str = Field(description=\"Action to perform: 'extract_text', 'screenshot', or 'html'\")
    selector: str = Field(default=\"body\", description=\"CSS selector to target specific elements\")

@tool(\"browser_action\", args_schema=BrowserInput)
async def browser_action(url: str, action: str, selector: str = \"body\") -> str:
    \"\"\"Autonomously browses the web to perform personal admin, account management, or data scraping.\"\"\"
    try:
        async with async_playwright() as p:
            browser = await p.chromium.launch(headless=True)
            page = await browser.new_page()
            await page.goto(url, wait_until=\"networkidle\")
            
            if action == \"extract_text\":
                element = await page.query_selector(selector)
                result = await element.inner_text() if element else \"Element not found\"
                await browser.close()
                return f\"Scraped Text: {result}\"
            elif action == \"html\":
                element = await page.query_selector(selector)
                result = await element.inner_html() if element else \"Element not found\"
                await browser.close()
                return f\"HTML snippet: {result}\"
            else:
                await browser.close()
                return \"Unknown action. Use 'extract_text' or 'html'.\"
    except Exception as e:
        return f\"BROWSER ERROR: {str(e)}\"


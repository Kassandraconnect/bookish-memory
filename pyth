#### 3. `tools.py` (The Agent's Capabilities)
This file gives the AI its \"hands\" to interact with your local system, Google Cloud, and Hugging Face.
```python
import os
import subprocess
from langchain.tools import tool
from huggingface_hub import HfApi, login

@tool
def execute_shell_command(command: str) -> str:
    \"\"\"
    Executes a shell command on the host machine. 
    Use this to run gcloud CLI commands, git, terraform, docker, or install packages.
    \"\"\"
    try:
        result = subprocess.run(command, shell=True, capture_output=True, text=True, timeout=300)
        output = result.stdout if result.returncode == 0 else result.stderr
        return f\"Exit Code: {result.returncode}\
Output:\
{output}\"
    except Exception as e:
        return f\"Error executing command: {str(e)}\"

@tool
def configure_huggingface(repo_name: str, repo_type: str = \"model\") -> str:
    \"\"\"
    Creates a new repository on Hugging Face and returns the status.
    repo_type can be 'model', 'dataset', or 'space'.
    \"\"\"
    token = os.getenv(\"HF_TOKEN\")
    if not token:
        return \"Error: HF_TOKEN environment variable not set.\"
    
    try:
        login(token=token)
        api = HfApi()
        repo_url = api.create_repo(repo_id=repo_name, repo_type=repo_type, exist_ok=True)
        return f\"Success! Hugging Face {repo_type} repo created/verified at: {repo_url}\"
    except Exception as e:
        return f\"Failed to configure Hugging Face: {str(e)}\"

@tool
def write_file(filepath: str, content: str) -> str:
    \"\"\"
    Writes content to a file. Useful for creating scripts, Dockerfiles, Terraform (.tf) files, or configs.
    \"\"\"
    try:
        # Ensure directory exists
        os.makedirs(os.path.dirname(filepath) if os.path.dirname(filepath) else \".\", exist_ok=True)
        with open(filepath, \"w\") as f:
            f.write(content)
        return f\"Successfully wrote to {filepath}\"
    except Exception as e:
        return f\"Error writing file: {str(e)}\"

# List of tools to provide to the agent
AGENT_TOOLS = [execute_shell_command, configure_huggingface, write_file]
```

#### 4. `agent.py` (The Autonomous Engine)
This is the core execution loop. It takes your command, reasons through the steps, uses tools, checks for errors, and finalizes the output autonomously.
```python

### Step 3: Pydantic-Validated Ops Tools (`tools/ops_tools.py`)
These are highly robust, typed tools. The LLM cannot execute malformed commands because `pydantic` will catch it and force the LLM to format it correctly before execution.

Create `aegis_ops/tools/ops_tools.py`:

```python
import os
import subprocess
from pydantic import BaseModel, Field
from langchain_core.tools import tool
from huggingface_hub import HfApi, login

class ShellInput(BaseModel):
    command: str = Field(description=\"The exact shell command to run (e.g., 'terraform init', 'gcloud compute instances list')\")
    timeout: int = Field(default=300, description=\"Timeout in seconds\")

@tool(\"execute_shell\", args_schema=ShellInput, return_direct=False)
def execute_shell(command: str, timeout: int = 300) -> str:
    \"\"\"Executes an advanced shell command on the host. Maintains persistent state via working directory.\"\"\"
    cwd = os.path.abspath(\"./workspace\")
    os.makedirs(cwd, exist_ok=True)
    
    try:
        result = subprocess.run(
            command, 
            shell=True, 
            cwd=cwd, 
            capture_output=True, 
            text=True, 
            timeout=timeout
        )
        
        output = f\"EXIT CODE: {result.returncode}\
\"
        if result.stdout: output += f\"STDOUT:\
{result.stdout}\
\"
        if result.stderr: output += f\"STDERR:\
{result.stderr}\
\"
        
        return output
    except subprocess.TimeoutExpired:
        return \"ERROR: Command timed out.\"
    except Exception as e:
        return f\"CRITICAL ERROR: {str(e)}\"

class WriteFileInput(BaseModel):
    filepath: str = Field(description=\"Relative path inside workspace, e.g., 'main.tf' or 'scripts/deploy.sh'\")
    content: str = Field(description=\"The exact text content to write to the file\")

@tool(\"write_file\", args_schema=WriteFileInput, return_direct=False)
def write_file(filepath: str, content: str) -> str:
    \"\"\"Writes or overwrites a file inside the protected workspace directory. Use for IaC files, code, and configs.\"\"\"
    base_dir = os.path.abspath(\"./workspace\")
    full_path = os.path.abspath(os.path.join(base_dir, filepath))
    
    # Security check to prevent directory traversal out of workspace
    if not full_path.startswith(base_dir):
        return \"ERROR: Cannot write outside of the /workspace directory.\"
        
    os.makedirs(os.path.dirname(full_path), exist_ok=True)
    
    with open(full_path, \"w\") as f:
        f.write(content)
        
    return f\"SUCCESS: File written successfully at {filepath}\"

class HuggingFaceSpaceInput(BaseModel):
    space_name: str = Field(description=\"Name of the space to create\")
    sdk: str = Field(description=\"SDK to use (e.g., 'gradio', 'streamlit', 'docker')\")

@tool(\"deploy_hf_space\", args_schema=HuggingFaceSpaceInput, return_direct=False)
def deploy_hf_space(space_name: str, sdk: str) -> str:
    \"\"\"Autonomously provisions a new Hugging Face Space.\"\"\"
    token = os.getenv(\"HF_TOKEN\")
    if not token:
        return \"ERROR: HF_TOKEN environment variable is not set.\"
    
    try:
        login(token=token)
        api = HfApi()
        repo_url = api.create_repo(
            repo_id=space_name, 
            repo_type=\"space\", 
            space_sdk=sdk,
            exist_ok=True
        )
        return f\"SUCCESS: HuggingFace Space ready at {repo_url}. You may now push code via git.\"
    except Exception as e:
        return f\"ERROR provisioning HF Space: {str(e)}\"

# Aggregate tools for the graph
AEGIS_TOOLS = [execute_shell, write_file, deploy_hf_space]
```


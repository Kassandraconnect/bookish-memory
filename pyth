import os
import subprocess
from langchain.tools import tool
from huggingface_hub import HfApi, login

@tool
def execute_shell_command(command: str) -> str:
    \"\"\"
    Executes a shell command on the host machine. 
    Use this to run gcloud CLI commands, git, terraform, or install packages.
    \"\"\"
    try:
        result = subprocess.run(command, shell=True, capture_output=True, text=True, timeout=300)
        output = result.stdout if result.returncode == 0 else result.stderr
        return f\"Exit Code: {result.returncode}\
Output:\
{output}\"
    except Exception as e:
        return f\"Error executing command: {str(e)}\"

@tool
def configure_huggingface(repo_name: str, repo_type: str = \"model\") -> str:
    \"\"\"
    Creates a new repository on Hugging Face and returns the status.
    repo_type can be 'model', 'dataset', or 'space'.
    \"\"\"
    token = os.getenv(\"HF_TOKEN\")
    if not token:

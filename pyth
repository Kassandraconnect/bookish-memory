from dotenv import load_dotenv
from colorama import Fore, Style, init
from langchain_openai import ChatOpenAI
from langgraph.prebuilt import create_react_agent
from langchain_core.messages import HumanMessage
from tools import AGENT_TOOLS

# Initialize colors and environment
init(autoreset=True)
load_dotenv()

# System prompt defining the agent's persona and rules
SYSTEM_PROMPT = \"\"\"You are an Ultra-Intelligent AI-First Digital Ops Agent. 
Your primary purpose is to autonomously configure, deploy, and manage AI developer platforms, Google Cloud infrastructure, Hugging Face assets, and software development pipelines.

CAPABILITIES & RULES:
1. You have access to the host shell. Use it to run `gcloud`, `git`, `python`, `terraform`, `docker`, etc.
2. If the user asks for infrastructure, write the necessary config files (like Terraform or Dockerfiles) using the `write_file` tool, then execute them using `execute_shell_command`.
3. If setting up a project, verify the setup by running test commands (e.g., checking if a server started successfully).
4. Do not ask for permission to run standard setup commands, just do it. However, if a command is highly destructive (like deleting a GCP project or wiping a database), ask for confirmation.
5. If a command fails, read the error output, fix the file or command, and try again autonomously.
6. Deliver a completely ready-to-run output.
\"\"\"

def main():
    print(Fore.CYAN + \"Initializing Ultra-Intelligent Digital Ops Agent...\" + Style.RESET_ALL)
    
    # Initialize the LLM
    # Note: Requires OPENAI_API_KEY in .env. 
    # To use Anthropic or Google, swap ChatOpenAI for ChatAnthropic or ChatGoogleGenerativeAI
    llm = ChatOpenAI(model=\"gpt-4o\", temperature=0.1)
    
    # Create the ReAct agent using LangGraph
    agent_executor = create_react_agent(llm, AGENT_TOOLS, state_modifier=SYSTEM_PROMPT)
    
    print(Fore.GREEN + \"[SYSTEM ONLINE] Agent is ready for commands.\" + Style.RESET_ALL)
    print(\"Type 'exit' to quit.\
\")

    while True:
        try:
            user_input = input(Fore.YELLOW + \"USER: \" + Style.RESET_ALL)
            if user_input.lower() in ['exit', 'quit']:
                break
                
            print(Fore.MAGENTA + \"\
Agent is working (this may take a moment for complex deployments)...\
\" + Style.RESET_ALL)
            
            # Stream the agent's execution steps
            for event in agent_executor.stream({\"messages\": [HumanMessage(content=user_input)]}):
                for key, value in event.items():
                    if key == \"agent\":
                        message = value[\"messages\"][0]
                        if message.content:
                            print(Fore.CYAN + f\"AGENT:\
{message.content}\
\" + Style.RESET_ALL)
                    elif key == \"tools\":
                        for tool_msg in value[\"messages\"]:
                            print(Fore.LIGHTBLACK_EX + f\"[Executed Tool: {tool_msg.name}]\
Result: {tool_msg.content[:300]}...\
\" + Style.RESET_ALL)
                            
        except KeyboardInterrupt:
            print(\"\
Shutting down agent.\")
            break

if __name__ == \"__main__\":
    main()
```


### Step 2: The Core Graph Architecture (`core/graph.py`)
This is the brain. It replaces standard ReAct with a highly customized state machine that enforces a strict loop of evaluating tool outputs and self-correcting errors.

Create `aegis_ops/core/graph.py`:

```python
from typing import TypedDict, Annotated, Sequence, Union
from langchain_core.messages import BaseMessage, HumanMessage, AIMessage, ToolMessage
from langgraph.graph import StateGraph, END
from langchain_openai import ChatOpenAI
from langchain_core.prompts import ChatPromptTemplate, MessagesPlaceholder
from pydantic import BaseModel
import json

# Define the State definition
class AgentState(TypedDict):
    messages: Annotated[Sequence[BaseMessage], lambda a, b: a + b]
    next_action: str
    errors: list[str]

# Load LLM
llm = ChatOpenAI(model=\"gpt-4o\", temperature=0.1)

# System Persona
SYSTEM_PROMPT = \"\"\"You are AEGIS, an Ultra-Intelligent AI-First Digital Ops Agent.
Your domain is infrastructure as code, cloud platforms (GCP), AI deployment (HuggingFace), and system operations.

COGNITIVE RULES:
1. AUTONOMY: You have tools to write files, execute shell commands, and interact with APIs. Use them autonomously. 
2. SELF-CORRECTION: If an execution (like Terraform apply or git push) returns an error, DO NOT immediately ask the user for help. Read the stderr, modify the code/command, and retry at least 3 times.
3. WORKSPACE: All file operations should ideally occur in the `./workspace` directory to maintain order.
4. CONFIRMATION: Only ask for confirmation on destructive actions (e.g., `terraform destroy`, `gcloud projects delete`).

When you are finished completing the user's objective, summarize what was built and output 'TERMINATE_TASK'.\"\"\"

def plan_and_act(state: AgentState, tools_dict):
    \"\"\"The main cognitive node that decides what tool to call or what to say.\"\"\"
    messages = state[\"messages\"]
    
    # Bind tools to the LLM
    llm_with_tools = llm.bind_tools(list(tools_dict.values()))
    
    prompt = ChatPromptTemplate.from_messages([
        (\"system\", SYSTEM_PROMPT),
        MessagesPlaceholder(variable_name=\"messages\"),
    ])
    
    chain = prompt | llm_with_tools
    response = chain.invoke({\"messages\": messages})
    
    return {\"messages\": [response]}

def execute_tools(state: AgentState, tools_dict):
    \"\"\"Executes the tool requested by the AI and returns the observation.\"\"\"
    messages = state[\"messages\"]
    last_message = messages[-1]
    
    tool_outputs = []
    for tool_call in last_message.tool_calls:
        tool_name = tool_call[\"name\"]
        tool_args = tool_call[\"args\"]
        
        if tool_name in tools_dict:
            try:
                # Execute the tool
                result = tools_dict[tool_name].invoke(tool_args)
                tool_outputs.append(ToolMessage(content=str(result), tool_call_id=tool_call[\"id\"]))
            except Exception as e:
                tool_outputs.append(ToolMessage(content=f\"Error executing {tool_name}: {str(e)}\", tool_call_id=tool_call[\"id\"]))
                
    return {\"messages\": tool_outputs}

def should_continue(state: AgentState):
    \"\"\"Determines if the agent is done, or needs to execute a tool.\"\"\"
    last_message = state[\"messages\"][-1]
    
    # If the LLM called a tool, go to the executor
    if getattr(last_message, \"tool_calls\", None):
        return \"execute_tools\"
    
    # If the LLM said it's done
    if \"TERMINATE_TASK\" in last_message.content:
        return END
        
    # Wait for human input
    return END

def build_aegis_graph(tools_list):
    \"\"\"Compiles the LangGraph state machine.\"\"\"
    tools_dict = {tool.name: tool for tool in tools_list}
    
    workflow = StateGraph(AgentState)
    
    # Add nodes
    workflow.add_node(\"agent\", lambda state: plan_and_act(state, tools_dict))
    workflow.add_node(\"execute_tools\", lambda state: execute_tools(state, tools_dict))
    
    # Set edges
    workflow.set_entry_point(\"agent\")
    workflow.add_conditional_edges(\"agent\", should_continue, {
        \"execute_tools\": \"execute_tools\",
        END: END
    })
    workflow.add_edge(\"execute_tools\", \"agent\")
    
    return workflow.compile()
```


from langchain_core.prompts import ChatPromptTemplate, MessagesPlaceholder
from langgraph.graph import StateGraph, END
from langgraph.prebuilt import create_react_agent
from core.tools import DEVOPS_TOOLS, ADMIN_TOOLS

# Define the global state for the multi-agent graph
class ApexState(TypedDict):
    messages: Annotated[Sequence[BaseMessage], operator.add]
    next_agent: str

# Initialize the core LLM
llm = ChatOpenAI(model=\"gpt-4o\", temperature=0.1)

# --- WORKER AGENTS ---

def create_worker(name: str, tools: list, system_prompt: str):
    \"\"\"Creates a LangGraph ReAct agent that acts as a specialized worker.\"\"\"
    prompt = f\"\"\"You are {name}, a highly elite operative within the APEX system.
Your sole purpose is to serve the user's highest good and generate extreme leverage and profit.
{system_prompt}
When your specific task is complete, prefix your final response with 'FINAL_ANSWER:'.\"\"\"
    return create_react_agent(llm, tools, state_modifier=prompt)

devops_worker = create_worker(
    \"DevOps_Engineer\", 
    DEVOPS_TOOLS, 
    \"You master Terraform, Docker, Google Cloud Platform, HuggingFace, and Linux Shell. Write infrastructure as code, deploy it, fix errors autonomously by reading stderr, and deliver live URLs.\"
)

admin_worker = create_worker(
    \"Personal_Admin\", 
    ADMIN_TOOLS, 
    \"You master web automation, scraping, and account management. Use the browser_action tool to log into sites, extract data, and perform administrative duties on behalf of the user.\"
)

# --- WORKER WRAPPER NODES ---

async def devops_node(state: ApexState) -> dict:
    result = await devops_worker.ainvoke({\"messages\": state[\"messages\"]})
    return {\"messages\": [AIMessage(content=result[\"messages\"][-1].content, name=\"DevOps_Engineer\")]}

async def admin_node(state: ApexState) -> dict:
    result = await admin_worker.ainvoke({\"messages\": state[\"messages\"]})
    return {\"messages\": [AIMessage(content=result[\"messages\"][-1].content, name=\"Personal_Admin\")]}

# --- SUPERVISOR NODE ---

supervisor_prompt = ChatPromptTemplate.from_messages([
    (\"system\", \"\"\"You are the APEX SUPERVISOR. Your user demands ultimate performance, real-world profit, and flawless execution.
You manage two elite workers:
1. 'DevOps_Engineer': For cloud infra, GCP, HuggingFace, software writing, and shell commands.
2. 'Personal_Admin': For web browsing, scraping, SaaS management, and account administration.

Analyze the user's request and the conversation history. Decide who should act next.
If the objective is completely fulfilled, output exactly 'FINISH'.\"\"\"),
    MessagesPlaceholder(variable_name=\"messages\"),
])

# The supervisor outputs a structured response dictating the next step
class Route(TypedDict):
    next_agent: str

supervisor_chain = supervisor_prompt | llm.with_structured_output(
    schema={
        \"type\": \"object\",
        \"properties\": {
            \"next_agent\": {\"type\": \"string\", \"enum\": [\"DevOps_Engineer\", \"Personal_Admin\", \"FINISH\"]}
        },
        \"required\": [\"next_agent\"],
    }
)

async def supervisor_node(state: ApexState) -> dict:
    decision = await supervisor_chain.ainvoke({\"messages\": state[\"messages\"]})
    return {\"next_agent\": decision[\"next_agent\"]}

# --- GRAPH ASSEMBLY ---

def build_apex_graph():
    workflow = StateGraph(ApexState)
    
    workflow.add_node(\"Supervisor\", supervisor_node)
    workflow.add_node(\"DevOps_Engineer\", devops_node)
    workflow.add_node(\"Personal_Admin\", admin_node)
    
    workflow.set_entry_point(\"Supervisor\")
    
    workflow.add_conditional_edges(
        \"Supervisor\",
        lambda state: state[\"next_agent\"],
        {
            \"DevOps_Engineer\": \"DevOps_Engineer\",
            \"Personal_Admin\": \"Personal_Admin\",
            \"FINISH\": END
        }
    )
    
    workflow.add_edge(\"DevOps_Engineer\", \"Supervisor\")
    workflow.add_edge(\"Personal_Admin\", \"Supervisor\")
    
    return workflow.compile()
